{
  "$schema": "https://stripe.com/stripe-app.schema.json",
  "id": "com.example.pizzazz-loyalty",
  "name": "Pizzazz Loyalty",
  "version": "0.0.1",
  "icon": "brand_icon.png",
  "ui_extension": {
    "views": [
      {
        "viewport": "stripe.dashboard.fullpage",
        "component": "FullPage"
      },
      {
        "viewport": "settings",
